<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F2">

    <!--ENCABEZADO REUTILIZABLE CON COMPONENTE-->
    <com.odvsystem.sportcenter.components.Header
        android:id="@+id/encabezado"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>
    <!--CARD BLANCA CONTENEDORA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="14dp"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:elevation="4dp">

        <!-- BUSCADOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="14sp"
                android:layout_marginEnd="6dp" />

            <EditText
                android:id="@+id/etBuscar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Buscar por nombre o DNI..."
                android:textColorHint="#AAAAAA"
                android:textColor="#333333"
                android:textSize="13sp"
                android:background="@null"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/gridSocios"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:columnCount="4"
            android:rowCount="1"
            android:useDefaultMargins="false"
            android:alignmentMode="alignMargins">

            <!-- Encabezado NOMBRE -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="0"
                android:layout_columnWeight="2.2"
                android:text="NOMBRE"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="4dp" />

            <!-- Encabezado ACTIVIDAD -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="1"
                android:layout_row="0"
                android:layout_columnWeight="1.5"
                android:text="ACTIVIDAD"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

            <!-- Encabezado MONTO -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="2"
                android:layout_row="0"
                android:layout_columnWeight="1.3"
                android:text="MONTO"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

            <!-- Encabezado FECHA -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="3"
                android:layout_row="0"
                android:layout_columnWeight="1.3"
                android:text="FECHA"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />


        </GridLayout>

        <!-- Línea divisora (va entre encabezados y datos,
             la ponemos fija aquí como referencia visual) -->
        <!-- NOTA: en la versión dinámica esta línea la podés agregar
             también con addView() como un View separador desde Kotlin -->

        <!--BOTONES DE ACCIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="+ Registrar No Socio"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:backgroundTint="#2E7D32"
                android:elevation="0dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>