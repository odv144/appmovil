<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@color/fondoGris">
    <!--ENCABEZADO REUTILIZABLE CON COMPONENTE-->
    <com.odvsystem.sportcenter.components.Header
        android:id="@+id/encabezado"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Badges resumen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#83FDFDFD"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvVencidos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 vencidos"
                        android:textColor="#C62828"
                        android:background="@drawable/bg_badge_naranjaclaro"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvProximos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 próximos"
                        android:textColor="#E65100"
                        android:background="@drawable/bg_card_white"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvAlDia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="40 al día"
                        android:textStyle="bold"
                        android:textColor="@color/verde_oscuro"
                        android:background="@drawable/bg_badge_verde"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Tabla -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_white">

                    <!-- Encabezado tabla -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="NOMBRE"
                            android:textColor="#1B5E20"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.25"
                            android:text="PERÍODO"
                            android:textColor="#1B5E20"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.35"
                            android:text="MONTO"
                            android:textColor="#1B5E20"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.7"
                            android:text="VENCE"
                            android:textColor="#1B5E20"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:text="EST."
                            android:textColor="#1B5E20"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#7CE0E0E0" />

                    <!-- Filas de la lista -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerVencimientos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
                <Button
                    android:id="@+id/btnCobrarCuota"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_margin="12dp"
                    android:text="Cobrar cuota"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:backgroundTint="#2E7D32" />
            </LinearLayout>

        </ScrollView>

        <!-- Botón inferior -->


    </LinearLayout>

