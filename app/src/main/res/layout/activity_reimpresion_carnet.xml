<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F2">

    <include layout="@layout/component_header" />

    <!-- ===== CONTENIDO ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ETIQUETA VISTA PREVIA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VISTA PREVIA DEL CARNET"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="10dp" />

            <!-- ===== CARNET ===== -->
            <LinearLayout
                android:id="@+id/cardCarnet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1B5E20"
                android:padding="16dp">

                <!-- ENCABEZADO -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SPORT CENTER · CARNET DE SOCIO"
                    android:textColor="#A5D6A7"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <!-- NOMBRE -->
                <TextView
                    android:id="@+id/tvNombreSocio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="García, Luis"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <!-- DNI Y NRO SOCIO -->
                <TextView
                    android:id="@+id/tvDniSocio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DNI: 30.123.456 · Socio Nº 0048"
                    android:textColor="#A5D6A7"
                    android:textSize="11sp"
                    android:layout_marginBottom="16dp" />

                <!-- ACTIVIDAD / VIGENCIA / ESTADO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVIDAD"
                            android:textColor="#A5D6A7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tvActividad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fútbol"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIGENCIA"
                            android:textColor="#A5D6A7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tvVigencia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04/2025"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ESTADO"
                            android:textColor="#A5D6A7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/tvEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Al día"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- FRANJA INFERIOR QR + MEMBRESÍA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0D3B18"
                    android:padding="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="#4CAF50" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado de membresía"
                            android:textColor="#A5D6A7"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvEstadoMembresia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Activo y al día"
                            android:textColor="#4CAF50"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTÓN IMPRIMIR ===== -->
    <Button
        android:id="@+id/btnImprimirCarnet"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Imprimir carnet"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:backgroundTint="#2E7D32"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

</LinearLayout>