<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">
    <!--ENCABEZADO REUTILIZABLE CON COMPONENTE-->
    <com.odvsystem.sportcenter.components.Header
        android:id="@+id/encabezado"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"/>
    <!--CONTENIDO PARA EL FORMULARIO DATOS PERSONALES-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical"
        android:background="@color/fondoGris">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATOS PERSONALES"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/verde_oscuro"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DNI"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NOMBRE"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="APELLIDO"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="TELEFONO"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />

    </LinearLayout>
    <!--CONTENIDO PARA MEMBRESIA-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical"
        android:background="@color/fondoGris">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEMBRESÍA"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/verde_oscuro"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="DNI"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ACTIVIDAD"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="COUTA MENSUAL"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="FORMA DE PAGO"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="CERTIFICADO. MÉDICO"
            android:background="@color/white"
            android:padding="3dp"
            android:layout_marginTop="5dp"
            />


    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <android.widget.Button
            android:id="@+id/btnGuardar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="15dp"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:background="@color/verde_oscuro"
            android:text="Guardar" />
        <android.widget.Button
            android:id="@+id/btnLimpiar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="15dp"
            android:background="@color/white"
            android:textSize="20sp"
            android:text="limpiar" />


    </LinearLayout>

</LinearLayout>