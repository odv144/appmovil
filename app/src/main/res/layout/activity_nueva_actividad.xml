<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F2">

    <com.odvsystem.sportcenter.components.Header
        android:id="@+id/encabezado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
    <!-- ===== CARD BLANCA PRINCIPAL ===== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="14dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- ENCABEZADOS DE TABLA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATOS DE LAS ACTIVIDADES"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <!-- LÍNEA DIVISORA SUPERIOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/linea_divisora" />

            <!-- FORMULARIO EN FORMATO TABLA -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <!-- FILA: NOMBRE -->
                <TableRow
                    android:padding="8dp"
                    android:background="@android:color/white">
                    <TextView
                        android:text="Nombre"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etNombreActividad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Natación"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                <View android:layout_height="4dp" />

                <!-- FILA: DESCRIPCIÓN -->
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Descripción"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Natación para principiantes"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                <View android:layout_height="4dp" />

                <!-- FILA: TURNO -->
                <!--
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Turno"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etTurno"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Noche"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                -->
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Turno"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <Spinner
                        android:id="@+id/spinnerTurno"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="4dp" />
                </TableRow>
                <View android:layout_height="4dp" />

                <!-- FILA: CUPO MÁXIMO -->
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Cupo Máximo"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etCupo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="10"
                        android:inputType="number"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                <View android:layout_height="4dp" />

                <!-- FILA: TARIFA DIARIA -->
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Tarifa Diaria"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etTarifaDiaria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="10000"
                        android:inputType="numberDecimal"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                <View android:layout_height="4dp" />

                <!-- FILA: TARIFA MENSUAL -->
                <TableRow
                    android:padding="8dp">
                    <TextView
                        android:text="Tarifa Mensual"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="16dp"/>
                    <EditText
                        android:id="@+id/etTarifaMensual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="25000"
                        android:inputType="numberDecimal"
                        android:background="@null"
                        android:textSize="14sp"/>
                </TableRow>
                <View android:layout_height="4dp" />

            </TableLayout>

            <!-- BOTONES DE ACCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:text="Guardar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLimpiar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:text="Limpiar"
                    android:textAllCaps="false"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:strokeWidth="1"
                    android:strokeColor="#2E7D32"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>