<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_gradient"
    android:paddingStart="40dp"
    android:paddingEnd="40dp">

    <!-- Ícono estrella en círculo -->
    <!-- Título: SPORT CENTER -->
    <ImageView
        android:id="@+id/imgEstrella"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="28dp"
        android:contentDescription="@string/desc_logo"
        android:src="@drawable/ic_estrella_circulo" />

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_portada"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- Subtítulo: GESTIÓN DEPORTIVA -->
    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitulo_portada"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:textStyle="normal"
        android:letterSpacing="0.25"
        android:gravity="center"
        android:layout_marginBottom="52dp" />

    <!-- Botón Iniciar sesión -->
    <android.widget.Button
        android:id="@+id/btnIniciarSesion"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:background="@drawable/btn_white_pill"
        android:elevation="0dp"
        android:letterSpacing="0.02"
        android:stateListAnimator="@null"
        android:text="@string/btn_iniciar_sesion"
        android:textAllCaps="false"
        android:textColor="#2E7D32"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>