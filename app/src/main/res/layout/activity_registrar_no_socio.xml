<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.odvsystem.sportcenter.components.Header
            android:id="@+id/encabezado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- DATOS DEL VISITANTE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="36dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="DATOS DEL VISITANTE"
                android:textColor="#0D6B2A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <EditText
                android:id="@+id/etDni"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="DNI"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Nombre"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etApellido"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Apellido"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Teléfono"
                android:inputType="phone"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@android:color/transparent"
                android:hint="E-mail"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ACTIVIDAD DEL DÍA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="36dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="ACTIVIDAD DEL DÍA"
                android:textColor="#0D6B2A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <EditText
                android:id="@+id/etActividad"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Actividad"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etCuota"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Tarifa del día"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etFormaPago"
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:background="@drawable/bg_form_row"
                android:hint="Forma de pago"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="Cert. médico"
                    android:textColor="#555555"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/chkCerti"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Presentado"
                    android:textColor="#9A9A9A"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="36dp"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCobrar"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_green"
                android:text="Registrar y cobrar"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLimpiar"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_outline"
                android:text="Limpiar"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>