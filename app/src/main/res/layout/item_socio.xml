<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:descendantFocusability="blocksDescendants">

    <!-- Columna NOMBRE + DNI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"

        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="García, Luis"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDni"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="30.123.456"
            android:textColor="#999999"
            android:textSize="11sp" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <!-- Columna ACTIVIDAD -->
        <TextView
            android:id="@+id/tvActividad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Completo"
            android:textColor="#444444"
            android:textSize="13sp"/>

        <!-- Columna ESTADO — el color se cambia desde el Adapter en Kotlin -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Al día"
            android:textSize="11sp"
            android:textStyle="bold"

            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textColor="#2E7D32" />
    </LinearLayout>
    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <android.widget.Button
            android:id="@+id/btnDetalle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:backgroundTint="#163A00"
            android:text="Ver"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            android:textColor="#FFFFFF" />

        <android.widget.Button
            android:id="@+id/btnEditar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:backgroundTint="#FFAB00"
            android:text="Editar"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"

            android:textColor="#FFFFFF" />

        <android.widget.Button
            android:id="@+id/btnEliminar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:backgroundTint="#D50000"
            android:text="Eliminar"
            android:textSize="12sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
